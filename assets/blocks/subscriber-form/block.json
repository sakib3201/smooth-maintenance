{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "smooth-maintenance/subscriber-form",
    "version": "1.1.0",
    "title": "Subscriber Form",
    "category": "design",
    "icon": "email",
    "description": "Capture email subscribers directly from your maintenance page.",
    "supports": {
        "html": false,
        "color": {
            "text": true,
            "background": false
        }
    },
    "attributes": {
        "placeholder": {
            "type": "string",
            "default": "Enter your email address..."
        },
        "buttonText": {
            "type": "string",
            "default": "Notify Me"
        },
        "successMessage": {
            "type": "string",
            "default": "Thanks! You've been subscribed."
        },
        "containerBackgroundColor": {
            "type": "string",
            "default": ""
        },
        "containerBorderColor": {
            "type": "string",
            "default": ""
        },
        "containerBorderRadius": {
            "type": "number",
            "default": 50
        },
        "containerPadding": {
            "type": "number",
            "default": 8
        },
        "containerBorderWidth": {
            "type": "number",
            "default": 1
        },
        "inputTextColor": {
            "type": "string",
            "default": ""
        },
        "inputPlaceholderColor": {
            "type": "string",
            "default": ""
        },
        "inputBackgroundColor": {
            "type": "string",
            "default": ""
        },
        "inputBorderColor": {
            "type": "string",
            "default": ""
        },
        "inputBorderRadius": {
            "type": "number",
            "default": 50
        },
        "inputFontSize": {
            "type": "number",
            "default": 16
        },
        "buttonTextColor": {
            "type": "string",
            "default": ""
        },
        "buttonBackgroundColor": {
            "type": "string",
            "default": ""
        },
        "buttonHoverBackgroundColor": {
            "type": "string",
            "default": ""
        },
        "buttonBorderColor": {
            "type": "string",
            "default": ""
        },
        "buttonBorderRadius": {
            "type": "number",
            "default": 50
        },
        "buttonFontSize": {
            "type": "number",
            "default": 16
        },
        "buttonFontWeight": {
            "type": "number",
            "default": 700
        },
        "successTextColor": {
            "type": "string",
            "default": ""
        },
        "successBackgroundColor": {
            "type": "string",
            "default": ""
        },
        "successBorderColor": {
            "type": "string",
            "default": ""
        },
        "successBorderRadius": {
            "type": "number",
            "default": 20
        }
    },
    "textdomain": "smooth-maintenance",
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./style-index.css",
    "viewScript": "file:./view.js"
}