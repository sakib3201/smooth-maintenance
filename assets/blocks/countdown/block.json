{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "smooth-maintenance/countdown",
    "version": "1.1.0",
    "title": "Countdown Timer",
    "category": "design",
    "icon": "clock",
    "description": "A high-performance countdown timer for your maintenance page.",
    "supports": {
        "html": false,
        "color": {
            "background": false
        },
        "typography": {
            "fontSize": true
        }
    },
    "attributes": {
        "endDate": {
            "type": "string"
        },
        "expiredMessage": {
            "type": "string",
            "default": "We are live!"
        },
        "numberColor": {
            "type": "string",
            "default": ""
        },
        "labelColor": {
            "type": "string",
            "default": ""
        }
    },
    "textdomain": "smooth-maintenance",
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./style-index.css",
    "viewScript": "file:./view.js"
}