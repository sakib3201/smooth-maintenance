{
    "name": "smooth-maintenance",
    "version": "1.0.0",
    "description": "Smooth Maintenance WordPress plugin - Admin interface",
    "private": true,
    "scripts": {
        "start": "wp-scripts start assets/admin/src/index.js --output-path=build",
        "build": "wp-scripts build assets/admin/src/index.js --output-path=build",
        "test": "vitest",
        "test:coverage": "vitest --coverage",
        "lint:js": "wp-scripts lint-js assets/admin/src/",
        "format": "wp-scripts format assets/admin/src/"
    },
    "dependencies": {
        "@wordpress/api-fetch": "^7.0.0",
        "@wordpress/components": "^28.0.0",
        "@wordpress/data": "^10.0.0",
        "@wordpress/element": "^6.0.0",
        "@wordpress/i18n": "^5.0.0",
        "@wordpress/notices": "^5.0.0"
    },
    "devDependencies": {
        "@wordpress/scripts": "^27.0.0",
        "vitest": "^1.0.0",
        "@testing-library/react": "^14.0.0",
        "jsdom": "^23.0.0"
    }
}